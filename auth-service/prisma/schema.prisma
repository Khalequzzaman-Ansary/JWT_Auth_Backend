generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  legacyId      String    @unique @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  password      String?
  isVerified    Boolean   @default(false)
  otpHash       String?
  otpExpiresAt  DateTime?
  Account       Account[]
  Comment       Comment[]
  Post          Post[]
  Project       Project[]
  Session       Session[]
  Vote          Vote[]
}

model Account {
  id                String  @id
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Comment {
  id        String   @id
  content   String
  createdAt DateTime @default(now())
  postId    String
  userId    Int
  Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String    @id
  title       String
  slug        String    @unique
  description String
  status      Status    @default(OPEN)
  category    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  userId      Int
  projectId   String
  Comment     Comment[]
  Project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Vote        Vote[]
}

model Project {
  id        String   @id
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  userId    Int
  Post      Post[]
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vote {
  postId String
  userId Int
  Post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
}

enum Role {
  USER
  ADMIN
}

enum Status {
  OPEN
  PLANNED
  IN_PROGRESS
  LIVE
  CLOSED
}
